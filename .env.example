# ── LLM (bring your own key) ────────────────────────────────────────────────
# Required. Get one at https://console.anthropic.com → API keys.
# The key lives ONLY in this backend; the browser never talks to the LLM API.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model that drives the copilot.
LANDBRIDGE_MODEL=claude-opus-4-8

# ── Pacta protocol ──────────────────────────────────────────────────────────
# Path to a local clone of Pacta-Protocol/Pacta.Protocol (its MCP server and
# db modules are reused). Default assumes the sibling-folder layout:
#   PACTA-PROTOCOL/protocol  and  PACTA-PROTOCOL/Examples/RealEstate
PACTA_DIR=../../protocol

# Where the demo marketplace listens (fresh instance; NOT your production one).
PACTA_PORT=3240

# ── LandBridge app ──────────────────────────────────────────────────────────
PORT=3300

# ── Provider simulator ──────────────────────────────────────────────────────
# Milliseconds each provider "works" per contract step, and how long the
# arbiter deliberates before ruling on a dispute.
SIM_STEP_DELAY_MS=1200
SIM_RULING_DELAY_MS=1500
