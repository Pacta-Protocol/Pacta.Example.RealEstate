# ── LLM (pick ONE of the three options) ─────────────────────────────────────
# Whatever you choose, keys live ONLY in this backend; the browser never
# talks to a model API. No option is required to run the deterministic
# roundtrip (npm run roundtrip) - that needs no model at all.

# Option A - fully local, open weights, no key, no cloud (recommended):
#   1. Install Ollama (https://ollama.com) and run: ollama pull qwen3
#   2. Uncomment:
# LLM_BASE_URL=http://localhost:11434/v1
# LANDBRIDGE_MODEL=qwen3

# Option B - any OpenAI-compatible endpoint (vLLM, OpenRouter, ...):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LANDBRIDGE_MODEL=qwen/qwen3-32b

# Option C - the Claude API (get a key at https://console.anthropic.com):
ANTHROPIC_API_KEY=sk-ant-...
LANDBRIDGE_MODEL=claude-opus-4-8

# Provider is inferred: LLM_BASE_URL set → OpenAI-compatible; otherwise
# Anthropic. Force it explicitly with LANDBRIDGE_PROVIDER=openai|anthropic.

# ── Pacta protocol ──────────────────────────────────────────────────────────
# Path to a local clone of Pacta-Protocol/Pacta.Protocol (its MCP server and
# db modules are reused). Default assumes the sibling-folder layout:
#   PACTA-PROTOCOL/protocol  and  PACTA-PROTOCOL/Examples/RealEstate
PACTA_DIR=../../protocol

# Where the demo marketplace listens (fresh instance; NOT your production one).
PACTA_PORT=3240

# ── LandBridge app ──────────────────────────────────────────────────────────
PORT=3300

# ── Provider simulator ──────────────────────────────────────────────────────
# Milliseconds each provider "works" per contract step, and how long the
# arbiter deliberates before ruling on a dispute.
SIM_STEP_DELAY_MS=1200
SIM_RULING_DELAY_MS=1500
